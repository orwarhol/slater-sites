---
import { render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import GuideLayout from "../../../layouts/GuideLayout.astro";
import { isLocale, LOCALE_LABELS, LOCALE_HTML_LANG } from "../../../lib/locales";
import {
	getGuideEntries,
	groupBySlug,
	resolveGuide,
	localeSlotsFor,
} from "../../../lib/guides";

const { locale, slug } = Astro.params;

if (!isLocale(locale) || !slug) {
	return new Response(null, { status: 404, statusText: "Not found" });
}

const groups = groupBySlug(await getGuideEntries());
const group = groups.get(slug);
const resolved = group ? resolveGuide(group, locale) : undefined;

if (!group || !resolved) {
	Astro.response.status = 404;
}

const Content = resolved ? (await render(resolved.entry)).Content : undefined;
const slots = group ? localeSlotsFor(group) : [];
---

{
	resolved && Content ? (
		<GuideLayout resolved={resolved} slots={slots}>
			<Content />
		</GuideLayout>
	) : (
		<BaseLayout
			title="Guide unavailable — Global Field Guide"
			description="This guide is not yet available in any edition."
			locale={locale}
			htmlLang={LOCALE_HTML_LANG[locale]}
		>
			<section class="intro">
				<p class="eyebrow">{LOCALE_LABELS[locale]} edition</p>
				<h1>This guide isn’t available yet</h1>
				<p>
					We don’t have this guide in the {LOCALE_LABELS[locale]} edition or
					any edition it can fall back to.
				</p>
			</section>
			<a class="back-link" href={`/${locale}/`}>
				← All {LOCALE_LABELS[locale]} guides
			</a>
		</BaseLayout>
	)
}
