{
  "version": "1.0.0",
  "engine": "git-backed",
  "workspace": {
    "framework": "astro",
    "contentRoot": "src/content/blog",
    "extension": "md",
    "monorepoSubdir": "apps/ian-site"
  },
  "schema": {
    "strictValidation": true,
    "fields": [
      {
        "name": "title",
        "type": "string",
        "uiComponent": "text-input",
        "required": true,
        "aiAnchor": true
      },
      {
        "name": "description",
        "type": "string",
        "uiComponent": "textarea",
        "required": false,
        "aiAnchor": true
      },
      {
        "name": "pubDate",
        "type": "date",
        "uiComponent": "date-picker",
        "required": true,
        "aiAnchor": false
      },
      {
        "name": "heroImage",
        "type": "image",
        "uiComponent": "image-picker",
        "required": false,
        "aiAnchor": false
      }
    ]
  },
  "regionalization": {
    "enabled": false
  },
  "contentLibrary": {
    "collections": [
      {
        "id": "blog",
        "label": "Blog Posts",
        "contentRoot": "src/content/blog",
        "extension": "md",
        "titleField": "title",
        "descriptionField": "description",
        "dateField": "pubDate",
        "defaultSort": "-pubDate",
        "surfaces": ["draft", "paste", "optimize"]
      }
    ]
  }
}
