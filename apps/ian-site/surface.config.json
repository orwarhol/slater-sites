{
  "version": "1.0.0",
  "engine": "git-backed",
  "workspace": {
    "framework": "astro",
    "contentRoot": "src/content/blog",
    "extension": "md",
    "monorepoSubdir": "apps/ian-site"
  },
  "schema": {
    "strictValidation": true,
    "fields": [
      {
        "name": "title",
        "type": "string",
        "uiComponent": "text-input",
        "required": true,
        "aiAnchor": true
      },
      {
        "name": "description",
        "type": "string",
        "uiComponent": "textarea",
        "required": false,
        "aiAnchor": true
      },
      {
        "name": "pubDate",
        "type": "date",
        "uiComponent": "date-picker",
        "required": true,
        "aiAnchor": false
      },
      {
        "name": "heroImage",
        "type": "image",
        "uiComponent": "image-picker",
        "assetRoot": "ian-site-public-images",
        "required": false,
        "aiAnchor": false
      },
      {
        "name": "date",
        "type": "date",
        "uiComponent": "date-picker",
        "required": false,
        "aiAnchor": false
      },
      {
        "name": "type",
        "type": "enum",
        "uiComponent": "select",
        "options": [
          "feature screenplay",
          "short screenplay",
          "TV script",
          "novel",
          "feature film",
          "short film"
        ],
        "required": false,
        "aiAnchor": false
      },
      {
        "name": "genre",
        "type": "array",
        "uiComponent": "tag-cloud",
        "items": "string",
        "required": false,
        "aiAnchor": false
      },
      {
        "name": "pages",
        "type": "number",
        "uiComponent": "number-input",
        "required": false,
        "aiAnchor": false
      }
    ]
  },
  "regionalization": {
    "enabled": false
  },
  "contentLibrary": {
    "collections": [
      {
        "id": "blog",
        "label": "Blog Posts",
        "contentRoot": "src/content/blog",
        "extension": "md",
        "titleField": "title",
        "descriptionField": "description",
        "dateField": "pubDate",
        "defaultSort": "-pubDate",
        "surfaces": [
          "draft",
          "paste",
          "optimize"
        ],
        "fields": [
          "title",
          "description",
          "pubDate",
          "heroImage"
        ]
      },
      {
        "id": "projects",
        "label": "Projects",
        "contentRoot": "src/content/projects",
        "extension": "md",
        "titleField": "title",
        "descriptionField": "description",
        "dateField": "date",
        "defaultSort": "-date",
        "surfaces": [
          "draft",
          "paste",
          "generate",
          "optimize"
        ],
        "fields": [
          "title",
          "description",
          "date",
          "heroImage",
          "type",
          "genre",
          "pages"
        ]
      }
    ]
  },
  "media": {
    "assetRoots": [
      {
        "id": "ian-site-public-images",
        "label": "Ian Site public images",
        "systemPath": "public",
        "publicPrefix": "/",
        "allowedCollections": [
          "blog",
          "projects"
        ],
        "readOnly": false
      }
    ],
    "uploadPolicy": {
      "maxSizeBytes": 5242880,
      "allowedMimeTypes": [
        "image/jpeg",
        "image/png",
        "image/webp"
      ],
      "allowedExtensions": [
        "jpg",
        "jpeg",
        "png",
        "webp"
      ],
      "namingStrategy": "{contentSlug}-{hash}-{originalName}.{ext}",
      "onCollision": "append-hash",
      "sanitizeSvg": true
    }
  },
  "generate": {
    "enabled": true
  }
}
