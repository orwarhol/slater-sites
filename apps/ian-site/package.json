{
	"name": "ian-site",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"build": "astro check && astro build",
		"postbuild": "node -e \"require('fs').copyFileSync('.assetsignore','dist/.assetsignore')\"",
		"preview": "astro preview",
		"astro": "astro",
		"test": "vitest run tests/unit",
		"test:unit": "vitest run tests/unit",
		"test:integration": "vitest run tests/integration --maxWorkers=1",
		"test:all": "vitest run",
		"test:playwright": "playwright test --config playwright.config.ts"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.0",
		"@astrojs/cloudflare": "13.7.0",
		"@astrojs/mdx": "5.0.4",
		"@astrojs/rss": "4.0.19",
		"@astrojs/sitemap": "3.7.2",
		"astro": "6.4.6",
		"typescript": "5.9.3"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1"
	}
}
