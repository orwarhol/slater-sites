{
	"name": "slater-sites",
	"description": "Monorepo for Ian and Charles Slater personal websites",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*"
	],
	"scripts": {
		"dev:ian": "npm run dev --workspace=ian-site",
		"dev:dad": "npm run dev --workspace=dad-site",
		"build:ian": "npm run build --workspace=ian-site",
		"build:dad": "npm run build --workspace=dad-site",
		"test:ian": "npm run test --workspace=ian-site",
		"test:dad": "npm run test --workspace=dad-site",
		"test:ian:integration": "npm run test:integration --workspace=ian-site",
		"test:dad:integration": "npm run test:integration --workspace=dad-site"
	},
	"devDependencies": {
		"turndown": "^7.2.0",
		"vitest": "^4.0.18",
		"wrangler": "^4.73.0"
	},
	"overrides": {
		"h3": "1.15.11",
		"wrangler": "^4.73.0",
		"lodash": "4.17.23",
		"fast-xml-parser": ">=5.7.1",
		"rollup": ">=4.59.0",
		"svgo": ">=4.0.1",
		"undici": ">=7.24.0",
		"devalue": ">=5.6.4",
		"picomatch": ">=2.3.2",
		"smol-toml": ">=1.6.1",
		"yaml": ">=2.8.3",
		"@astrojs/language-server": ">=2.16.5",
		"@astrojs/cloudflare": {
			"wrangler": "^4.73.0",
			"undici": ">=7.24.0",
			"vite": ">=6.4.2 <7"
		},
		"astro": {
			"vite": ">=6.4.2 <7"
		}
	}
}
